# Rust build artifacts
/target
Cargo.lock.bak

# Editor / OS noise
.DS_Store
*.swp

# Claude Code project-level state (per-project, not source)
.claude/

# CCB daemon runtime state (per-machine, not source)
.ccb/

# ccbd-rust daemon runtime state + dev/abort snapshots (per-machine, not source)
# Matches .ah/, .ah.tmp-*, .ah.aborted-*, .ah.archive-* etc.
.ah*
!.ah/
.ah/*
!.ah/rules/
!.ah/rules/*.md

# Timestamped test fixture scratch files (auto-generated by integration tests)
r3-fixture-*.txt

# SQLite WAL/SHM (Cargo build/test transients)
*.sqlite-shm
*.sqlite-wal

# Research corpus — Claude session originals collected for design study.
# Contains private conversation history; NEVER commit to a public remote.
/research/sessions/
research/candidates/

# Upstream agent CLI documentation mirror (kept locally for grep, not source-of-truth)
docs/agent-cli-knowledge-base/

# Research corpus build artifacts (auto-generated from sessions/, do not commit)
research/findings/per-day-chunks/
research/findings/per-day-raw/
research/findings/per-day-stderr/
research/findings/per-day-progress.log

# Operator/worker blocking-question sentinels (runtime signal files, not source)
.operator-question
.lane-question

# Ad-hoc debug captures: transcripts / diffs / run logs (per-run, may contain tokens)
# NOTE: *.jsonl is intentionally NOT ignored — tests/fixtures/*.jsonl are tracked fixtures.
/conversation.jsonl
*.patch
*.log
research/ah-master-death-cutover-incident/*.jsonl

# Superseded / draft scratch (kept locally, never source-of-truth)
*.SUPERSEDED*
*.toml-draft
ah.toml.old-*
*-rescued.txt
